    <!-- Accessibility Service for Call Recording -->
    <string name="accessibility_service_label">Call Recording Audio</string>
    <string name="accessibility_service_description">Enables reliable call audio capture. This service allows the dialer to record both sides of phone calls. It does not read or interact with screen content.</string>
    <string name="accessibility_service_required">Enable accessibility service for reliable call recording</string>
    <string name="accessibility_service_required_summary">Required to capture both sides of the conversation on most devices. Tap to open Accessibility settings.</string>
    <string name="accessibility_service_enabled">Accessibility service enabled ✓</string>
    <string name="accessibility_service_disabled">Accessibility service not enabled</string>

